<view class="bk-page">
  <!-- Month Picker -->
  <view class="card month-picker">
    <view class="month-arrow" bindtap="onPrevMonth" hover-class="month-arrow-pressed">
      <van-icon name="arrow-left" size="16px" color="#ea580c" />
    </view>
    <text class="month-display">{{currentMonthLabel}}</text>
    <view class="month-arrow {{canGoNext ? '' : 'month-arrow-disabled'}}" bindtap="onNextMonth" hover-class="{{canGoNext ? 'month-arrow-pressed' : ''}}">
      <van-icon name="arrow" size="16px" color="{{canGoNext ? '#ea580c' : '#d6cfc7'}}" />
    </view>
  </view>

  <!-- Summary Cards -->
  <view class="summary-row">
    <view class="summary-card">
      <text class="sc-label">支出</text>
      <text class="sc-value expense-amount">{{expenseText}}</text>
    </view>
    <view class="summary-card">
      <text class="sc-label">收入</text>
      <text class="sc-value income-amount">{{incomeText}}</text>
    </view>
    <view class="summary-card">
      <text class="sc-label">结余</text>
      <text class="sc-value {{balanceIsPositive ? 'income-amount' : 'expense-amount'}}">{{balanceText}}</text>
    </view>
  </view>

  <!-- Category Rank Bars -->
  <view class="card rank-card" wx:if="{{expenseRankBars.length > 0}}">
    <text class="rank-title">支出排行</text>
    <view class="rank-item" wx:for="{{expenseRankBars}}" wx:key="cat1">
      <text class="rank-emoji">{{item.emoji}}</text>
      <text class="rank-cat">{{item.cat1}}</text>
      <view class="rank-bar-track">
        <view class="rank-bar-fill" style="width: {{item.barWidth}}%;"></view>
      </view>
      <text class="rank-amount">{{item.amountText}}</text>
      <text class="rank-pct">{{item.pct}}%</text>
    </view>
  </view>

  <!-- Empty State -->
  <view wx:if="{{!hasTransactions}}" class="empty-state">
    <view class="empty-state-icon">
      <van-icon name="todo-list-o" size="28px" color="#bfb5aa" />
    </view>
    <text class="empty-state-title">暂无记录</text>
    <text class="empty-state-desc">点击下方按钮开始记账</text>
  </view>

  <!-- Transaction List -->
  <block wx:else>
    <view class="txn-date-group" wx:for="{{transactionGroups}}" wx:key="dateKey">
      <view class="date-header">
        <text class="date-label">{{item.dateLabel}}</text>
        <text class="date-total {{item.dayTotalClass}}" wx:if="{{item.dayTotalText}}">{{item.dayTotalText}}</text>
      </view>
      <view class="txn-row" wx:for="{{item.list}}" wx:for-item="txn" wx:key="id" data-id="{{txn.id}}" bindtap="onTapTransaction" hover-class="txn-row-hover">
        <text class="txn-emoji">{{txn.emoji}}</text>
        <view class="txn-detail">
          <text class="txn-cat">{{txn.cat1}} · {{txn.cat2}}</text>
          <text class="txn-meta" wx:if="{{txn.hasMeta}}">{{txn.metaText}}</text>
        </view>
        <text class="txn-amount {{txn.amountClass}}">{{txn.amountText}}</text>
      </view>
    </view>
  </block>

  <!-- FAB Button (current month) -->
  <view class="fab-btn" bindtap="onTapFAB" hover-class="fab-btn-hover" wx:if="{{isCurrentMonth}}">
    <text class="fab-text">+ 记一笔</text>
  </view>

  <!-- Import Button -->
  <view class="fab-btn fab-btn-left" bindtap="onOpenImport" hover-class="fab-btn-hover">
    <van-icon name="down" class="import" size="16px" />
    <text class="fab-text">导入</text>
  </view>

  <!-- Add Modal -->
  <van-popup show="{{showAddModal}}" position="bottom" round z-index="2000"
    close-on-click-overlay="{{false}}" bind:close="onCancelAdd">
    <view class="modal-sheet">
      <text class="modal-title">记一笔</text>
      <text class="modal-date">{{addDateText}}</text>

      <!-- Type Toggle -->
      <view class="type-toggle">
        <view class="type-opt {{addType === 'expense' ? 'type-active' : ''}}"
          data-type="expense" bindtap="onSwitchType" hover-class="type-opt-hover">
          <text>支出</text>
        </view>
        <view class="type-opt {{addType === 'income' ? 'type-active' : ''}}"
          data-type="income" bindtap="onSwitchType" hover-class="type-opt-hover">
          <text>收入</text>
        </view>
      </view>

      <!-- Category1 Chips -->
      <text class="modal-label">一级分类</text>
      <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="chip {{index === addCat1Index ? 'chip-selected' : ''}}"
          wx:for="{{addCat1List}}" wx:key="*this" 
          data-index="{{index}}" bindtap="onSelectCat1" hover-class="chip-hover">{{item}}</view>
      </scroll-view>

      <!-- Category2 Chips -->
      <text class="modal-label">二级分类</text>
      <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="chip {{index === addCat2Index ? 'chip-selected' : ''}}"
          wx:for="{{addCat2List}}" wx:key="*this" 
          data-index="{{index}}" bindtap="onSelectCat2" bindlongpress="onLongPressCat2" hover-class="chip-hover">{{item}}</view>
        <view class="chip chip-add" bindtap="onAddCat2" hover-class="chip-hover">+</view>
      </scroll-view>

      <!-- Amount -->
      <text class="modal-label">金额</text>
      <view class="amount-row">
        <text class="amount-yuan">¥</text>
        <input type="digit" class="amount-input" value="{{addAmount}}"
          placeholder="0.00" bindinput="onAmountInput" maxlength="12" />
      </view>

      <!-- Account -->
      <block wx:if="{{addAccountList.length > 0}}">
        <text class="modal-label">支付账户（选填）</text>
        <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="chip {{index === addAccountIndex ? 'chip-selected' : ''}}"
            wx:for="{{addAccountList}}" wx:key="value"
            data-index="{{index}}" bindtap="onSelectAccount" hover-class="chip-hover">{{item.name}}</view>
        </scroll-view>
      </block>

      <!-- Note -->
      <text class="modal-label">备注（选填）</text>
      <input class="note-input" value="{{addNote}}" placeholder="添加备注..."
        bindinput="onNoteInput" maxlength="50" />

      <!-- Buttons -->
      <view class="modal-btn-row">
        <view class="btn btn-cancel" bindtap="onCancelAdd" hover-class="btn-cancel-hover">
          <text>取消</text>
        </view>
        <view class="btn btn-confirm" bindtap="onConfirmAdd" hover-class="btn-confirm-hover">
          <text>确认</text>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- Import Modal -->
  <van-popup show="{{showImportModal}}" position="bottom" round z-index="2000"
    close-on-click-overlay="{{false}}" bind:close="onImportCancel">
    <view class="modal-sheet">
      <text class="modal-title">导入交易记录</text>
      <text class="modal-date">粘贴JSON数据，格式：[{"date":"2026-05-30","type":"expense","category1":"餐饮","category2":"午饭","amount":25.5,"account":"","note":""}]</text>
      <textarea class="import-textarea" value="{{importJsonText}}"
        placeholder="粘贴JSON数据..."
        bindinput="onImportJsonInput" auto-height maxlength="-1" />
      <view class="modal-btn-row">
        <view class="btn btn-cancel" bindtap="onImportCancel" hover-class="btn-cancel-hover">
          <text>取消</text>
        </view>
        <view class="btn btn-confirm" bindtap="onImportConfirm" hover-class="btn-confirm-hover">
          <text>确认导入</text>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- Toast -->
  <view class="bk-toast {{toastShow ? 'bk-toast-show' : ''}}">{{toastMsg}}</view>
</view>
