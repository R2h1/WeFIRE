<view class="history-page">
  <view class="profile-card card">
    <view class="profile-avatar">
      <text class="avatar-text">W</text>
    </view>
    <text class="profile-name">WeFIRE</text>
    <text class="profile-desc">本地数据 · 隐私安全</text>
  </view>

  <view class="card settings-card" bindtap="openSettingsModal">
    <view class="settings-header">
      <view class="settings-header-left">
        <view class="settings-icon">
          <text class="icon-target">T</text>
        </view>
        <text class="settings-title">FIRE 目标</text>
      </view>
      <view class="settings-chevron">
        <text>›</text>
      </view>
    </view>
    <view wx:if="{{settings}}" class="settings-body">
      <view class="settings-row">
        <text class="settings-row-label">目标金额</text>
        <text class="settings-row-value">{{targetAmountText}}</text>
      </view>
      <view class="settings-row">
        <text class="settings-row-label">退休年份</text>
        <text class="settings-row-value">{{settings.retirementYear}}年</text>
      </view>
    </view>
    <view wx:else class="settings-empty">
      <text>点击设置 FIRE 目标</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onSubscribe">
      <view class="menu-item-icon icon-bell">
        <text>!</text>
      </view>
      <text class="menu-item-text">订阅提醒</text>
      <button class="menu-item-action" plain="true">
        <text>›</text>
      </button>
    </view>
    <view class="menu-item" bindtap="onExport">
      <view class="menu-item-icon icon-export">
        <text>↑</text>
      </view>
      <text class="menu-item-text">导出备份</text>
      <button class="menu-item-action" plain="true">
        <text>›</text>
      </button>
    </view>
    <view class="menu-item" bindtap="onImport">
      <view class="menu-item-icon icon-import">
        <text>↓</text>
      </view>
      <text class="menu-item-text">导入恢复</text>
      <button class="menu-item-action" plain="true">
        <text>›</text>
      </button>
    </view>
  </view>

  <view class="menu-section danger-zone">
    <view class="menu-item" bindtap="onClearData">
      <view class="menu-item-icon icon-danger">
        <text>✕</text>
      </view>
      <text class="menu-item-text">清除所有数据</text>
      <button class="menu-item-action" plain="true">
        <text>›</text>
      </button>
    </view>
  </view>
</view>

<view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="noop">
    <text class="modal-title">设置 FIRE 目标</text>
    <view class="modal-field">
      <text class="modal-label">目标金额</text>
      <view class="input-wrapper">
        <input class="modal-input" type="digit" placeholder="输入你的 FIRE 目标金额" value="{{editTarget}}" bindinput="onEditTargetInput" />
      </view>
    </view>
    <view class="modal-field">
      <text class="modal-label">预计退休年份</text>
      <view class="input-wrapper">
        <input class="modal-input" type="digit" placeholder="输入预计退休的年份" value="{{editYear}}" bindinput="onEditYearInput" />
      </view>
    </view>
    <view class="modal-btns">
      <button class="modal-btn cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn confirm" bindtap="onSaveSettings">保存</button>
    </view>
  </view>
</view>