<view class="history-page">
  <view class="card">
    <text style="font-size:48px;display:block;margin-bottom:8px;text-align:center;">🧑</text>
    <text style="font-size:17px;font-weight:600;color:#1C1C1E;display:block;text-align:center;">WeFIRE</text>
    <text style="font-size:14px;color:#8E8E93;display:block;text-align:center;margin-top:4px;">财务独立进度追踪</text>
  </view>

  <!-- FIRE 目标总览 -->
  <view class="card settings-summary" bindtap="openSettingsModal">
    <view class="summary-header">
      <text class="summary-title">🎯 FIRE 目标</text>
      <text class="summary-arrow">›</text>
    </view>
    <view wx:if="{{settings}}" class="summary-body">
      <view class="summary-row">
        <text class="summary-label">目标金额</text>
        <text class="summary-value">{{targetAmountText}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">退休年份</text>
        <text class="summary-value">{{settings.retirementYear}}</text>
      </view>
    </view>
    <view wx:else class="summary-empty">
      <text>点击设置 FIRE 目标</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="onExport">
      <text class="menu-icon">💾</text>
      <text class="menu-text">导出备份</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onImport">
      <text class="menu-icon">📥</text>
      <text class="menu-text">导入恢复</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="danger-section">
    <view class="menu-item danger" bindtap="onClearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除所有数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

<!-- 编辑弹窗 -->
<view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="noop">
    <text class="modal-title">设置 FIRE 目标</text>
    <view class="modal-field">
      <text class="modal-label">目标金额</text>
      <view class="input-wrapper">
        <input class="modal-input" type="digit" placeholder="输入你的 FIRE 目标金额" value="{{editTarget}}" bindinput="onEditTargetInput" />
      </view>
    </view>
    <view class="modal-field">
      <text class="modal-label">预计退休年份</text>
      <view class="input-wrapper">
        <input class="modal-input" type="digit" placeholder="输入预计退休的年份" value="{{editYear}}" bindinput="onEditYearInput" />
      </view>
    </view>
    <view class="modal-btns">
      <button class="modal-btn cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn confirm" bindtap="onSaveSettings">保存</button>
    </view>
  </view>
</view>