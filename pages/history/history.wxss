/* ============================================
   History Page (我的)
   ============================================ */

.history-page {
  padding-bottom: 32px;
}

/* ============================================
   Profile Card
   ============================================ */

.profile-card {
  text-align: center;
  padding: 32px 20px 28px;
  margin-top: 16px;
}

.profile-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
}

.avatar-text {
  font-size: 24px;
  font-weight: 700;
  color: #2e7d32;
}

.profile-name {
  font-size: 18px;
  font-weight: 700;
  color: #1c1c1e;
  display: block;
  margin-bottom: 4px;
}

.profile-desc {
  font-size: 13px;
  color: #8e8e93;
  display: block;
}

/* ============================================
   Settings Card (FIRE Target)
   ============================================ */

.settings-card {
  padding: 20px;
}

.settings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.settings-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.settings-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-target {
  background: #e8f5e9;
  color: #2e7d32;
}

.settings-title {
  font-size: 16px;
  font-weight: 600;
  color: #1c1c1e;
}

.settings-chevron {
  font-size: 22px;
  color: #c7c7cc;
  line-height: 1;
}

.settings-body {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  background: #f2f2f7;
  border-radius: 12px;
}

.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.settings-row-label {
  font-size: 13px;
  color: #8e8e93;
}

.settings-row-value {
  font-size: 15px;
  font-weight: 600;
  color: #1c1c1e;
}

.settings-empty {
  padding: 16px;
  text-align: center;
  background: #f2f2f7;
  border-radius: 12px;
  color: #c7c7cc;
  font-size: 14px;
}

/* ============================================
   Vant Cell overrides for menu
   ============================================ */

van-cell-group {
  display: block;
  margin: 8px 16px;
  border-radius: 16px;
  overflow: hidden;
}

.van-cell-icon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  margin-right: 12px;
  flex-shrink: 0;
}

.icon-bell {
  background: #fff3e0;
  color: #e65100;
}

.icon-export {
  background: #e3f2fd;
  color: #1565c0;
}

.icon-import {
  background: #e8f5e9;
  color: #2e7d32;
}

.icon-danger {
  background: #ffebee;
  color: #d32f2f;
}

.danger-section {
  margin: 8px 16px;
  border-radius: 16px;
  overflow: hidden;
}

.danger-text {
  color: #d32f2f;
}

/* ============================================
   van-dialog content & field override
   ============================================ */

.van-dialog-content {
  padding: 24px 24px 0;
}

.van-dialog-title {
  display: block;
  font-size: 17px;
  font-weight: 700;
  color: #1c1c1e;
  text-align: center;
  margin-bottom: 16px;
}

/* Dialog 按钮圆角 */
.van-dialog {
  --van-dialog-border-radius: 16px;
}

.van-dialog .van-button {
  border-radius: 0 !important;
}

.van-dialog .van-button:first-child {
  border-bottom-left-radius: 16px !important;
}

.van-dialog .van-button:last-child {
  border-bottom-right-radius: 16px !important;
}

.van-dialog-content van-field {
  --van-field-background: #f2f2f7;
  padding: 2px 0;
}

.picker-value {
  color: #1c1c1e;
}

.picker-placeholder {
  color: #c7c7cc;
}

.picker-arrow {
  color: #c7c7cc;
}

/* ============================================
   Year Picker Popup
   ============================================ */

van-popup .van-picker {
  --van-picker-option-font-size: 18px;
  --van-picker-title-font-size: 16px;
  --van-picker-title-color: #1c1c1e;
  --van-picker-cancel-action-color: #8e8e93;
  --van-picker-confirm-action-color: #2e7d32;
}

van-popup .van-picker__toolbar {
  border-bottom: 1px solid #f2f2f7;
}
