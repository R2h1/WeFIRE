.history-page {
  padding-bottom: 30px;
}

.menu-item {
  background: #FFFFFF;
  margin: 1px 16px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.menu-item:first-child {
  border-radius: 16px 16px 0 0;
}

.menu-item:last-child {
  border-radius: 0 0 16px 16px;
}

.menu-item:only-child {
  border-radius: 16px;
}

.menu-item:active {
  background: #F2F2F7;
}

.menu-icon {
  font-size: 20px;
  width: 28px;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 15px;
  color: #1C1C1E;
}

.menu-arrow {
  font-size: 22px;
  color: #C7C7CC;
}

.danger-section {
  margin-top: 24px;
}

.menu-item.danger .menu-text {
  color: #FF3B30;
}

/* FIRE 目标总览卡片 */
.settings-summary {
  padding: 20px 24px;
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.summary-title {
  font-size: 15px;
  font-weight: 600;
  color: #1C1C1E;
}

.summary-arrow {
  font-size: 22px;
  color: #C7C7CC;
}

.summary-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}

.summary-label {
  font-size: 14px;
  color: #8E8E93;
}

.summary-value {
  font-size: 16px;
  font-weight: 600;
  color: #1C1C1E;
}

.summary-empty {
  padding: 8px 0;
  text-align: center;
  color: #C7C7CC;
  font-size: 14px;
}

/* 编辑弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 340px;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 28px 24px 20px;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 24px;
  text-align: center;
}

.modal-field {
  margin-bottom: 16px;
}

.modal-label {
  font-size: 13px;
  color: #8E8E93;
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.modal-input {
  width: 100%;
  padding: 14px 16px;
  background: #F2F2F7;
  border-radius: 12px;
  border: none;
  font-size: 17px;
  color: #1C1C1E;
  caret-color: #2E7D32;
}

.modal-input::placeholder {
  color: #C7C7CC;
}

.modal-btns {
  display: flex;
  gap: 10px;
  margin-top: 28px;
}

.modal-btn {
  flex: 1;
  border-radius: 12px;
  padding: 16px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  border: none;
}

.modal-btn.cancel {
  background: #F2F2F7;
  color: #1C1C1E;
}

.modal-btn.cancel:active {
  background: #E5E5EA;
}

.modal-btn.confirm {
  background: #2E7D32;
  color: #FFFFFF;
}

.modal-btn.confirm:active {
  background: #25682A;
}