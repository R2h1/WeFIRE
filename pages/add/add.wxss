/* ============================================
   Add Page Styles
   ============================================ */

.add-page {
  padding-bottom: 32px;
}

.add-page .card:first-child {
  margin-top: 16px;
}

.month-label {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #1C1C1E;
  text-align: center;
  margin-bottom: 28px;
  letter-spacing: 0.5px;
}

/* ============================================
   Section Header
   ============================================ */

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  margin-top: 8px;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.section-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}

.dot-assets {
  background: #2E7D32;
}

.dot-liabilities {
  background: #D32F2F;
}

.section-add {
  font-size: 14px;
  color: #2E7D32;
  font-weight: 600;
  padding: 6px 10px;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.section-add::after {
  border: none;
}

.section-add:active {
  opacity: 0.6;
}

.section-divider {
  height: 1px;
  background: #F2F2F7;
  margin: 20px 0;
}

/* ============================================
   Entry Row
   ============================================ */

.entry-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 0;
  border-bottom: 1px solid #F2F2F7;
}

.entry-row:last-child {
  border-bottom: none;
}

.entry-icon {
  font-size: 16px;
  width: 24px;
  text-align: center;
  flex-shrink: 0;
}

.entry-name {
  flex: 1;
  font-size: 14px;
  color: #1C1C1E;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.entry-label {
  color: #8E8E93;
  font-size: 12px;
}

.entry-amount {
  width: 100px;
  min-width: 80px;
  padding: 8px 12px;
  background: #F2F2F7;
  border-radius: 8px;
  border: none;
  font-size: 15px;
  color: #1C1C1E;
  text-align: right;
  caret-color: #2E7D32;
  height: 36px;
  box-sizing: border-box;
}

.entry-amount::placeholder {
  color: #C7C7CC;
}

.entry-amount:focus {
  background: #E8F5E9;
  outline: 2px solid rgba(46, 125, 50, 0.2);
  outline-offset: -2px;
}

.entry-del {
  font-size: 12px;
  color: #C7C7CC;
  padding: 6px;
  flex-shrink: 0;
  line-height: 1;
}

.entry-del:active {
  color: #FF3B30;
}

.empty-entries {
  padding: 24px 0;
  text-align: center;
}

.empty-entries text {
  font-size: 13px;
  color: #C7C7CC;
}

/* ============================================
   Preview
   ============================================ */

.preview {
  margin-top: 24px;
  padding: 24px 0 0;
  border-top: 1px solid #F2F2F7;
  text-align: center;
}

.preview-label {
  font-size: 11px;
  color: #C7C7CC;
  display: block;
  margin-bottom: 6px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.preview-amount {
  font-size: 36px;
  font-weight: 700;
  color: #2E7D32;
  letter-spacing: -1px;
  line-height: 1.1;
}

.btn-group-add {
  margin-top: 32px;
  padding: 0;
}

/* ============================================
   Picker Modal
   ============================================ */

.picker-content {
  width: 85%;
  max-width: 340px;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 24px 0 16px;
  display: flex;
  flex-direction: column;
}

.picker-title {
  font-size: 17px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  text-align: center;
  margin-bottom: 4px;
  padding: 0 24px;
}

.picker-list {
  max-height: 40vh;
  padding: 0 24px;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 0;
  border-bottom: 1px solid #F2F2F7;
}

.picker-item:active {
  opacity: 0.6;
}

.picker-icon {
  font-size: 18px;
  width: 28px;
  text-align: center;
}

.picker-name {
  font-size: 15px;
  color: #1C1C1E;
}

.picker-close {
  margin: 12px 24px 0;
  padding: 14px;
  background: #F2F2F7;
  border-radius: 12px;
  border: none;
  font-size: 16px;
  color: #1C1C1E;
  font-weight: 600;
  line-height: 1;
}

.picker-close::after {
  border: none;
}

.picker-close:active {
  background: #E5E5EA;
}

.label-input-content {
  padding: 24px 24px 20px;
}

/* ============================================
   History list inside Add page
   ============================================ */

.history-entry {
  padding: 14px 0;
  border-top: 1px solid #F2F2F7;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-entry:first-child {
  border-top: none;
}

.history-entry-label {
  font-size: 14px;
  color: #8E8E93;
}

.history-entry-value {
  font-size: 15px;
  font-weight: 600;
  color: #1C1C1E;
}