/* ============================================
   Add Page Styles
   ============================================ */

.add-page {
  padding: 0 0 calc(64px + 100px);
}

/* ===== Month Header ===== */
.month-header {
  display: inline-flex;
  align-items: baseline;
  justify-content: flex-start;
  padding: 10px 16px 4px;
  gap: 4px;
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(242, 242, 245, 0.3);
  border-radius: 0 8px 8px 0;
  margin-left: 0;
}

.month-header::after {
  content: '';
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: 0;
  height: 1px;
  background: rgba(0, 0, 0, 0.1);
}

.month-label-value {
  font-size: 18px;
  font-weight: 700;
  color: #1c1c1e;
  letter-spacing: 0.5px;
}

.month-icon {
  font-size: 20px;
  color: #2e7d32;
  margin-right: 4px;
}

/* ===== Previous Data Tip ===== */
.prev-data-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #e8f5e9;
  margin: 12px 16px 0;
  padding: 10px 16px;
  border-radius: 10px;
  font-size: 13px;
  color: #2e7d32;
}

.clear-link {
  color: #d32f2f;
  font-weight: 600;
  padding: 4px 8px;
  flex-shrink: 0;
}

.clear-link:active {
  opacity: 0.6;
}

.section-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 10px;
  --cell-font-size: 15px;
  --collapse-item-content-padding: 0 16px 12px;
  --van-collapse-item-content-font-size: 14px;
  --van-collapse-item-content-line-height: 1.5;
  --van-collapse-item-content-text-color: #1c1c1e;
}

.add-page .card:first-child {
  margin-top: 16px;
}

/* ===== Item Rows ===== */

.item-active {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f2f2f7;
}

.item-active:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 15px;
  color: #1c1c1e;
  flex-shrink: 0;
  width: 100px;
  word-break: break-all;
  line-height: 1.4;
  margin-right: 12px;
}

/* Single Item Input (van-field) */
.item-input-wrap {
  margin-left: auto;
  width: 100px;
  border-bottom: 1px solid #e5e5e5;
  --cell-vertical-padding: 4px;
  --cell-horizontal-padding: 0;
}

/* Multi Item Summary */
.item-multi {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-left: auto;
  cursor: pointer;
}

.item-multi:active {
  opacity: 0.6;
}

.multi-badge {
  font-size: 11px;
  color: #8e8e93;
}

.multi-total {
  font-size: 14px;
  font-weight: 600;
  color: #1c1c1e;
}

.multi-arrow {
  color: #c7c7cc;
  font-size: 14px;
}

/* ===== Section Empty State ===== */
.section-empty {
  padding: 24px 0;
  text-align: center;
}

.section-empty text {
  font-size: 14px;
  color: #c7c7cc;
}

/* ===== Section Add Button ===== */
.section-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 14px 0 6px;
  cursor: pointer;
}

.section-add-btn:active {
  opacity: 0.6;
}

.add-btn-icon {
  color: #2e7d32;
  font-size: 16px;
  font-weight: 600;
}

.add-btn-text {
  font-size: 14px;
  color: #2e7d32;
  font-weight: 500;
}

/* ===== Fixed Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  bottom: calc(56px + env(safe-area-inset-bottom));
  left: 8px;
  right: 8px;
  background: #ffffff;
  border-radius: 14px;
  box-shadow:
    0 -2px 12px rgba(0, 0, 0, 0.06),
    0 4px 16px rgba(0, 0, 0, 0.08);
  padding: 8px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.bottom-bar-left {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.bottom-bar-label {
  font-size: 10px;
  color: #8e8e93;
}

.bottom-bar-amount {
  font-size: 17px;
  font-weight: 700;
  color: #2e7d32;
  letter-spacing: -0.5px;
}

.submit-btn {
}

/* ===== Category Picker Popup ===== */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 12px;
  border-bottom: 1px solid #f2f2f7;
}

.picker-title {
  font-size: 17px;
  font-weight: 600;
  color: #1c1c1e;
}

.picker-close {
  color: #c7c7cc;
  font-size: 20px;
  padding: 4px;
}

.picker-list {
  padding: 8px 20px 32px;
  max-height: 360px;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid #f2f2f7;
  cursor: pointer;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item:active {
  opacity: 0.6;
}

.picker-item-active {
  opacity: 0.5;
}

.picker-item-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.picker-icon-on {
  color: #2e7d32;
  font-size: 18px;
}

.picker-icon-off {
  color: #c7c7cc;
  font-size: 18px;
}

.picker-item-name {
  font-size: 16px;
  color: #1c1c1e;
}

.picker-item-status {
  font-size: 13px;
  color: #2e7d32;
  font-weight: 500;
}

/* ===== Instance Popup ===== */
.instance-popup {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
}

.instance-popup-body {
  flex: 1;
  max-height: 360px;
  overflow-y: auto;
}

.instance-empty {
  padding: 40px 0;
  text-align: center;
  color: #c7c7cc;
  font-size: 14px;
}

.instance-add-btn {
  padding: 0px 20px 8px;
}

.inst-row {
  display: flex;
  align-items: center;
  padding: 0 20px;
}

.inst-name-wrap {
  flex: 0 0 100px;
  border-bottom: 1px solid #e5e5e5;
  --cell-vertical-padding: 4px;
  --cell-horizontal-padding: 0;
}

.inst-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.inst-amount-wrap {
  width: 100px;
  border-bottom: 1px solid #e5e5e5;
  --cell-vertical-padding: 4px;
  --cell-horizontal-padding: 0;
}

.inst-delete {
  font-size: 18px;
  color: #c7c7cc;
  padding: 8px 0 8px 16px;
  flex-shrink: 0;
}

.inst-delete:active {
  opacity: 0.6;
}
