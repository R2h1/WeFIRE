/* ============================================
   Add Page Styles
   ============================================ */

.add-page {
  padding-bottom: 32px;
}

.add-page .card:first-child {
  margin-top: 16px;
}

.month-label {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #1c1c1e;
  text-align: center;
  margin-bottom: 28px;
  letter-spacing: 0.5px;
}

/* ============================================
   Section Header
   ============================================ */

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  margin-top: 8px;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.section-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}

.dot-assets {
  background: #2e7d32;
}

.dot-liabilities {
  background: #d32f2f;
}

.section-divider {
  height: 1px;
  background: #f2f2f7;
  margin: 20px 0;
}

/* ============================================
   Entry Row
   ============================================ */

.entry-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 0;
  border-bottom: 1px solid #f2f2f7;
}

.entry-row:last-child {
  border-bottom: none;
}

.entry-icon {
  font-size: 16px;
  width: 24px;
  text-align: center;
  flex-shrink: 0;
}

.entry-name {
  flex: 1;
  font-size: 14px;
  color: #1c1c1e;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.entry-label {
  color: #8e8e93;
  font-size: 12px;
}

.entry-amount {
  width: 100px;
  min-width: 80px;
  padding: 8px 12px;
  background: #f2f2f7;
  border-radius: 8px;
  border: none;
  font-size: 15px;
  color: #1c1c1e;
  text-align: right;
  caret-color: #2e7d32;
  height: 36px;
  box-sizing: border-box;
}

.entry-amount::placeholder {
  color: #c7c7cc;
}

.entry-amount:focus {
  background: #e8f5e9;
  outline: 2px solid rgba(46, 125, 50, 0.2);
  outline-offset: -2px;
}

.entry-del {
  font-size: 12px;
  color: #c7c7cc;
  padding: 6px;
  flex-shrink: 0;
  line-height: 1;
}

.entry-del:active {
  color: #ff3b30;
}

.empty-entries {
  padding: 24px 0;
  text-align: center;
}

.empty-entries text {
  font-size: 13px;
  color: #c7c7cc;
}

/* ============================================
   Preview
   ============================================ */

.preview {
  margin-top: 24px;
  padding: 24px 0 0;
  border-top: 1px solid #f2f2f7;
  text-align: center;
}

.preview-label {
  font-size: 11px;
  color: #c7c7cc;
  display: block;
  margin-bottom: 6px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.preview-amount {
  font-size: 36px;
  font-weight: 700;
  color: #2e7d32;
  letter-spacing: -1px;
  line-height: 1.1;
}

.btn-group-add {
  margin-top: 32px;
  padding: 0;
}

/* Picker empty */
.picker-empty {
  padding: 30px 0;
  text-align: center;
  color: #c7c7cc;
  font-size: 14px;
}

/* ============================================
   Picker Modal
   ============================================ */

.picker-content {
  max-height: 60vh;
  padding: 24px 0 16px;
  display: flex;
  flex-direction: column;
}

van-popup .picker-content {
  background: #ffffff;
}

.picker-title {
  font-size: 17px;
  font-weight: 700;
  color: #1c1c1e;
  display: block;
  text-align: center;
  margin-bottom: 4px;
  padding: 0 24px;
}

.picker-list {
  max-height: 40vh;
  padding: 0 24px;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 0;
  border-bottom: 1px solid #f2f2f7;
}

.picker-item:active {
  opacity: 0.6;
}

.picker-icon {
  font-size: 18px;
  width: 28px;
  text-align: center;
}

.picker-name {
  font-size: 15px;
  color: #1c1c1e;
}

.label-input-content {
  padding: 24px 24px 20px;
}

/* ============================================
   History list inside Add page
   ============================================ */

.history-entry {
  padding: 14px 0;
  border-top: 1px solid #f2f2f7;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-entry:first-child {
  border-top: none;
}

.history-entry-label {
  font-size: 14px;
  color: #8e8e93;
}

.history-entry-value {
  font-size: 15px;
  font-weight: 600;
  color: #1c1c1e;
}
