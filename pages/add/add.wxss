.add-page {
  padding-bottom: 30px;
}

.month-label {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #1C1C1E;
  text-align: center;
  margin-bottom: 28px;
  letter-spacing: 0.5px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  margin-top: 8px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #1C1C1E;
}

.assets-title {
  color: #2E7D32;
}

.liabilities-title {
  color: #D32F2F;
}

.section-add {
  font-size: 14px;
  color: #2E7D32;
  font-weight: 600;
  padding: 4px 8px;
}

.section-add:active {
  opacity: 0.6;
}

.section-divider {
  height: 1px;
  background: #F2F2F7;
  margin: 20px 0;
}

.entry-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 0;
  border-bottom: 1px solid #F2F2F7;
}

.entry-icon {
  font-size: 18px;
  width: 24px;
  text-align: center;
}

.entry-name {
  flex: 1;
  font-size: 14px;
  color: #1C1C1E;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.entry-label {
  color: #8E8E93;
  font-size: 12px;
}

.entry-amount {
  width: 120px;
  padding: 8px 12px;
  background: #F2F2F7;
  border-radius: 8px;
  border: none;
  font-size: 15px;
  color: #1C1C1E;
  text-align: right;
  caret-color: #2E7D32;
  box-sizing: border-box;
}

.entry-amount::placeholder {
  color: #C7C7CC;
}

.entry-del {
  font-size: 14px;
  color: #C7C7CC;
  padding: 4px;
}

.entry-del:active {
  color: #FF3B30;
}

.empty-entries {
  padding: 20px 0;
  text-align: center;
}

.empty-entries text {
  font-size: 13px;
  color: #C7C7CC;
}

.preview {
  margin-top: 24px;
  padding: 24px 0 0;
  border-top: 1px solid #F2F2F7;
  text-align: center;
}

.preview-label {
  font-size: 11px;
  color: #C7C7CC;
  display: block;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.preview-amount {
  font-size: 34px;
  font-weight: 700;
  color: #2E7D32;
  letter-spacing: -1px;
  line-height: 1.1;
}

.btn-group-add {
  margin-top: 32px;
  padding: 0 16px;
}

/* Picker modal */
.picker-content {
  width: 85%;
  max-width: 340px;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 28px 0 16px;
  display: flex;
  flex-direction: column;
}

.picker-title {
  font-size: 17px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  text-align: center;
  margin-bottom: 12px;
  padding: 0 24px;
}

.picker-list {
  max-height: 40vh;
  padding: 0 24px;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 0;
  border-bottom: 1px solid #F2F2F7;
}

.picker-item:active {
  opacity: 0.6;
}

.picker-icon {
  font-size: 20px;
  width: 28px;
  text-align: center;
}

.picker-name {
  font-size: 16px;
  color: #1C1C1E;
}

.picker-close {
  margin: 12px 24px 0;
  padding: 14px;
  background: #F2F2F7;
  border-radius: 12px;
  border: none;
  font-size: 16px;
  color: #1C1C1E;
  font-weight: 600;
}

.picker-close:active {
  background: #E5E5EA;
}

.label-input-content {
  padding: 28px 24px 20px;
}
