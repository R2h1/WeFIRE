/* ============================================
   Add Page — 拟物态卡片（效率橙·Neumorphic）
   ============================================ */

.add-page {
  --bg: #f3efec;
  --card-bg: #fbf9f7;
  --shadow-dark: #d6cfc7;
  --shadow-light: #ffffff;
  --text: #2d2a26;
  --text-secondary: #8b827a;
  --text-muted: #bfb5aa;
  --accent: #ea580c;
  --accent-soft: #fff5f0;
  --accent-glow: rgba(234, 88, 12, 0.25);
  --danger: #c06c5c;
  --radius-sm: 10px;
  --radius: 14px;

  background: #e6e0da;
  min-height: 100vh;
  padding: 0 14px calc(52px + 64px + env(safe-area-inset-bottom));
}

/* ===== 月份行 ===== */
.month-row {
  font-size: 12px;
  color: var(--text-secondary);
  letter-spacing: 0.3px;
}

.month-value {
  font-weight: 600;
  color: var(--text);
  font-size: 14px;
}

/* ===== 上月数据提示条 ===== */
.prev-data-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  padding: 9px 14px;
  background: var(--accent-soft);
  border-radius: var(--radius-sm);
  font-size: 12px;
  color: var(--accent);
  letter-spacing: 0.2px;
  font-weight: 500;
}

.clear-link {
  color: var(--danger);
  font-size: 11px;
  font-weight: 500;
  padding: 4px 8px;
}

/* ===== 分区标题 ===== */
.section-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-secondary);
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 10px 2px 6px;
}

.section-title--asset {
  color: var(--accent);
}

.section-title--liability {
  color: var(--danger);
}

/* ===== 单实例横排容器 ===== */
.single-row {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

/* ===== 单实例卡片 ===== */
.single-card {
  flex: 1;
  min-width: 0;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 11px 10px;
  text-align: center;
  box-shadow:
    3px 3px 7px var(--shadow-dark),
    -3px -3px 7px var(--shadow-light);
  transition: box-shadow 0.15s ease;
}

.single-card-hover {
  box-shadow:
    inset 2px 2px 5px var(--shadow-dark),
    inset -2px -2px 5px var(--shadow-light);
}

.s-card-name {
  font-size: 11px;
  color: var(--text-secondary);
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.s-card-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  letter-spacing: -0.5px;
  min-height: 24px;
  line-height: 1.3;
}

.single-card input {
  width: 100%;
  border: none;
  background: transparent;
  font-size: 18px;
  font-weight: 700;
  color: var(--accent);
  text-align: center;
  outline: none;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  letter-spacing: -0.5px;
  padding: 0;
  min-height: 24px;
  line-height: 1.3;
}

/* ===== 多实例卡片 ===== */
.multi-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 13px 14px;
  margin-bottom: 8px;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
  transition: all 0.2s ease;
}

.multi-card.expanded {
  box-shadow:
    inset 3px 3px 8px rgba(0, 0, 0, 0.05),
    inset -3px -3px 8px rgba(255, 255, 255, 0.7);
  background: #f8f5f2;
}

.mc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mc-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.3px;
}

.mc-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.mc-value {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.mc-meta {
  font-size: 10px;
  color: var(--text-muted);
  background: #ede8e3;
  padding: 3px 7px;
  border-radius: 20px;
  letter-spacing: 0.2px;
}

.mc-arrow {
  font-size: 16px;
  color: var(--text-muted);
  transition: transform 0.2s ease;
  line-height: 1;
}

.multi-card.expanded .mc-arrow {
  transform: rotate(90deg);
}

.mc-expand {
  display: none;
  margin-top: 10px;
  border-top: 1px solid #ebe5de;
  padding-top: 8px;
}

.mc-expand.show {
  display: block;
}

/* ===== 实例行 ===== */
.inst-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 9px 6px;
  border-radius: 8px;
  font-size: 13px;
}

.inst-row-hover {
  background: rgba(0, 0, 0, 0.03);
}

.inst-name {
  color: var(--text);
  font-weight: 500;
}

.inst-val {
  color: var(--text);
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.inst-empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 12px;
  padding: 14px 0 8px;
  letter-spacing: 0.3px;
}

.add-inst {
  font-size: 12px;
  color: var(--accent);
  padding: 8px 6px;
  font-weight: 500;
  letter-spacing: 0.3px;
  width: 100%;
  text-align: left;
}

/* ===== 底部固定栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: calc(24px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 414px;
  background: var(--card-bg);
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.06);
  padding: 10px 16px;
  padding-bottom: max(10px, env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  z-index: 100;
  border-radius: 16px 16px 0 0;
  box-sizing: border-box;
}

.bottom-bar-left {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.nw-label {
  font-size: 10px;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.nw-value {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  letter-spacing: -0.5px;
}

.save-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  padding: 12px 36px;
  border-radius: 25px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 14px var(--accent-glow);
  line-height: 1.2;
}

.save-btn-hover {
  transform: scale(0.95);
  box-shadow: 0 2px 8px var(--accent-glow);
}

/* ===== 实例编辑弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 2000;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.modal-sheet {
  background: #fbf9f7;
  width: 100%;
  max-width: 414px;
  border-radius: 20px 20px 0 0;
  padding: 20px 18px 0px;
  box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.1);
}

.modal-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.3px;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.modal-header .modal-title {
  margin-bottom: 0;
}

.modal-delete {
  font-size: 13px;
  color: var(--danger);
  font-weight: 500;
  padding: 4px 8px;
}

.modal-form-group {
  margin-bottom: 12px;
}

.modal-form-group .form-label {
  font-size: 11px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 5px;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1.5px solid #e0d9d1;
  border-radius: var(--radius-sm);
  padding: 0 12px;
  font-size: 15px;
  color: var(--text);
  outline: none;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  background: #fff;
  box-sizing: border-box;
  line-height: 44px;
}

.form-input:focus {
  border-color: var(--accent);
}

.modal-btn-row {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.modal-btn-row .btn {
  flex: 1;
  padding: 12px;
  border-radius: 25px;
  font-size: 14px;
  font-weight: 600;
  text-align: center;
  letter-spacing: 0.3px;
}

.btn-danger {
  background: #ede8e3;
  color: var(--danger);
}

.btn-danger-hover {
  opacity: 0.7;
}

.btn-primary {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 3px 10px var(--accent-glow);
}

.modal-close {
  padding: 4px;
}

/* ===== Toast ===== */
.add-toast {
  position: fixed;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.85);
  background: rgba(45, 42, 38, 0.88);
  color: #fff;
  padding: 10px 22px;
  border-radius: 25px;
  font-size: 13px;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  transition: all 0.25s ease;
  letter-spacing: 0.3px;
  font-weight: 500;
}

.add-toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* ===== 补充 hover 态 ===== */
.mc-header-hover {
  opacity: 0.7;
}

.add-inst-hover {
  opacity: 0.6;
}

.btn-danger-hover {
  transform: scale(0.97);
  opacity: 0.7;
}

.btn-primary-hover {
  opacity: 0.8;
  transform: scale(0.97);
}
