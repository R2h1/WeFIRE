<view class="add-page">
  <!-- 上月数据提示条 -->
  <view wx:if="{{loadedFromPrev}}" class="prev-data-tip">
    <text>已加载上月数据，可直接保存</text>
    <text class="clear-link" bindtap="onClearForm">清空</text>
  </view>

  <!-- 分区循环 -->
  <block wx:for="{{sectionGroups}}" wx:key="id">
    <view class="section-title section-title--{{item.titleClass}}">{{item.label}}</view>

    <!-- 单实例卡片横排 -->
    <view wx:if="{{item.singleItems.length}}" class="single-row">
      <view
        wx:for="{{item.singleItems}}"
        wx:for-item="sItem"
        wx:key="key"
        class="single-card"
        hover-class="single-card-hover"
        data-section-id="{{item.id}}"
        data-key="{{sItem.key}}"
        bindtap="onSingleCardTap"
      >
        <view class="s-card-name">{{sItem.name}}</view>
        <view wx:if="{{!sItem.editing}}" class="s-card-value">{{sItem.displayValue}}</view>
        <input
          wx:else
          type="digit"
          value="{{sItem.editValue}}"
          data-section-id="{{item.id}}"
          data-key="{{sItem.key}}"
          bindinput="onSingleInput"
          bindblur="onSingleBlur"
          focus="{{sItem.editing}}"
          placeholder="0"
        />
      </view>
    </view>

    <!-- 多实例卡片 -->
    <view
      wx:for="{{item.multiItems}}"
      wx:for-item="mItem"
      wx:key="key"
      class="multi-card {{mItem.expanded ? 'expanded' : ''}}"
      data-section-id="{{item.id}}"
      data-key="{{mItem.key}}"
    >
      <view
        class="mc-header"
        hover-class="mc-header-hover"
        data-section-id="{{item.id}}"
        data-key="{{mItem.key}}"
        bindtap="onMultiToggle"
      >
        <text class="mc-name">{{mItem.name}}</text>
        <view class="mc-right">
          <text class="mc-value">{{mItem.totalText}}</text>
          <text class="mc-meta">{{mItem.count}}个</text>
          <text class="mc-arrow">›</text>
        </view>
      </view>
      <view class="mc-expand {{mItem.expanded ? 'show' : ''}}">
        <view wx:if="{{mItem.instances.length === 0}}" class="inst-empty">
          <text>暂无记录，点击下方添加</text>
        </view>
        <block wx:else>
          <view
            wx:for="{{mItem.instances}}"
            wx:for-item="inst"
            wx:key="id"
            class="inst-row"
            hover-class="inst-row-hover"
            data-section-id="{{item.id}}"
            data-key="{{mItem.key}}"
            data-index="{{index}}"
            bindtap="onEditInstance"
          >
            <text class="inst-name">{{inst.name}}</text>
            <text class="inst-val">{{inst.displayValue}}</text>
          </view>
        </block>
        <view
          class="add-inst"
          data-section-id="{{item.id}}"
          data-key="{{mItem.key}}"
          bindtap="onAddInstance"
        >+ 添加{{mItem.name}}</view>
      </view>
    </view>
  </block>

  <!-- 底部固定栏 -->
  <view class="bottom-bar">
    <view class="bottom-bar-left">
      <view class="nw-label">{{monthLabel}} · 净资产</view>
      <view class="nw-value">{{netWorthText}}</view>
    </view>
    <view class="save-btn" hover-class="save-btn-hover" bindtap="onSubmit">保存</view>
  </view>

  <!-- Toast -->
  <view class="add-toast {{toastShow ? 'show' : ''}}">{{toastMsg}}</view>

  <!-- 实例编辑弹窗 -->
  <van-popup
    show="{{showInstancePopup}}"
    position="bottom"
    bind:close="onInstancePopupClose"
    round
    z-index="{{2000}}"
    close-on-click-overlay="{{false}}"
  >
    <view class="modal-sheet">
      <view class="modal-header">
        <view class="modal-title">{{modalMode === 'edit' ? '编辑' : '添加'}}{{instanceConfig.name}}</view>
        <view class="modal-close" bindtap="onModalCancel">
          <van-icon name="cross" size="18px" color="#8B827A" />
        </view>
      </view>

      <view class="modal-form-group">
        <text class="form-label">名称</text>
        <input
          class="form-input"
          value="{{modalName}}"
          bindinput="onModalNameInput"
          placeholder="输入名称"
          maxlength="{{10}}"
        />
      </view>

      <view wx:for="{{instanceFields}}" wx:key="key" class="modal-form-group">
        <text class="form-label">{{item.label}}</text>
        <input
          class="form-input"
          type="digit"
          value="{{modalFieldValues[item.key]}}"
          data-field="{{item.key}}"
          bindinput="onModalFieldInput"
          placeholder="0"
          maxlength="{{12}}"
        />
      </view>

      <view class="modal-btn-row">
        <view wx:if="{{modalMode === 'edit'}}" class="btn btn-danger" hover-class="btn-danger-hover" bindtap="onModalDelete">删除</view>
        <view class="btn btn-primary" hover-class="btn-primary-hover" bindtap="onModalConfirm">保存</view>
      </view>
    </view>
  </van-popup>
</view>
