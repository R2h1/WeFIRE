<view class="add-page">
  <!-- 月份行 -->
  <view class="month-header">
    <van-icon name="calendar-o" class="month-icon" />
    <text class="month-label-value">{{monthLabel}}</text>
  </view>

  <!-- 提示条 -->
  <view wx:if="{{loadedFromPrev}}" class="prev-data-tip">
    <text>已加载上月数据，确认无变化可直接保存</text>
    <text class="clear-link" bindtap="onClearForm">清空重填</text>
  </view>

  <!-- 四个折叠面板 -->
  <view wx:for="{{sections}}" wx:key="id" class="card section-card" style="--cell-text-color: {{item.id === 'liquidAssets' || item.id === 'fixedAssets' ? '#2E7D32' : '#D32F2F'}}">
    <van-collapse value="{{activeSections}}" bind:change="onCollapseChange" border="{{false}}">
      <van-collapse-item
        name="{{item.id}}"
        title="{{item.label}}"
        icon="{{iconMap[item.id]}}"
        value="{{sectionTotals[item.id]}}"
      >
        <!-- 大类行 -->
        <block wx:for="{{item.items}}" wx:key="key">
          <view wx:if="{{activeItems[item.key]}}" class="item-row">
            <view class="item-active">
              <text class="item-name">{{item.name}}</text>

              <view wx:if="{{!item.multi}}" class="item-input-wrap">
                <van-field
                  value="{{singleValues[item.key]}}"
                  type="digit"
                  placeholder="{{item.placeholder}}"
                  maxlength="{{12}}"
                  data-key="{{item.key}}"
                  bind:input="onSingleInput"
                  border="{{false}}"
                  input-align="right"
                />
              </view>

              <view wx:else class="item-multi" bindtap="onManageInstances" data-key="{{item.key}}">
                <block wx:if="{{multiSummaries[item.key].count > 0}}">
                  <text class="multi-total">{{multiSummaries[item.key].totalText}}</text>
                  <text class="multi-badge">{{multiSummaries[item.key].count}}个</text>
                  <van-icon name="arrow" class="multi-arrow" />
                </block>
                <text wx:else class="multi-badge">0个</text>
              </view>
            </view>
          </view>
        </block>

        <!-- 空状态 -->
        <view wx:if="{{sectionEmpty[item.id]}}" class="section-empty">
          <text>暂无记录，点击下方添加</text>
        </view>

        <!-- 添加按钮 -->
        <view wx:if="{{item.addEnabled}}" class="section-add-btn" bindtap="onAddCategory" data-section="{{item.id}}">
          <van-icon name="plus" class="add-btn-icon" />
          <text class="add-btn-text">{{item.addText}}</text>
        </view>
      </van-collapse-item>
    </van-collapse>
  </view>

  <!-- 底部固定保存栏 -->
  <view class="bottom-bar">
    <view class="bottom-bar-left">
      <text class="bottom-bar-label">本月净资产</text>
      <text class="bottom-bar-amount">{{netWorthText}}</text>
    </view>
    <view class="bottom-bar-right">
      <van-button type="primary" bindtap="onSubmit" round disabled="{{!hasAnyItem}}" class="submit-btn" size="small" custom-style="max-width:90px">完成录入</van-button>
    </view>
  </view>

  <!-- 添加大类弹窗 -->
  <van-popup
    show="{{showCategoryPicker}}"
    position="bottom"
    bind:close="onPickerClose"
    round
  >
    <view class="picker-header">
      <text class="picker-title">{{pickerLabel}}</text>
      <van-icon name="close" class="picker-close" bindtap="onPickerClose" />
    </view>
    <view class="picker-list">
      <view
        wx:for="{{pickerCategories}}"
        wx:key="key"
        class="picker-item {{item.active ? 'picker-item-active' : ''}}"
        bindtap="onPickerItemTap"
        data-key="{{item.key}}"
      >
        <view class="picker-item-left">
          <van-icon wx:if="{{item.active}}" name="success" class="picker-icon-on" />
          <van-icon wx:else name="circle" class="picker-icon-off" />
          <text class="picker-item-name">{{item.name}}</text>
        </view>
        <text wx:if="{{item.active}}" class="picker-item-status">已添加</text>
      </view>
    </view>
  </van-popup>

  <!-- 实例管理弹窗 -->
  <van-popup
    show="{{showInstancePopup}}"
    position="bottom"
    bind:close="onInstancePopupClose"
    round
    z-index="{{2000}}"
  >
    <view class="instance-popup">
      <view class="picker-header">
        <text class="picker-title">{{instanceConfig.name}}管理</text>
        <van-icon name="close" class="picker-close" bindtap="onInstancePopupClose" />
      </view>

      <view class="instance-popup-body">
        <view wx:if="{{instances.length === 0}}" class="instance-empty">
          <text>暂无记录，点击下方添加</text>
        </view>
        <view wx:else>
          <view wx:for="{{instances}}" wx:for-item="inst" wx:for-index="instIndex" wx:key="id" class="inst-row">
            <view class="inst-name-wrap">
              <van-field
                value="{{inst.name}}"
                data-index="{{instIndex}}"
                bind:input="onInstNameInput"
                maxlength="{{10}}"
                placeholder="名称"
                input-align="left"
                border="{{false}}"
              />
            </view>
            <view class="inst-right">
              <view class="inst-amount-wrap">
                <van-field
                  value="{{inst.f0}}"
                  type="digit"
                  data-index="{{instIndex}}"
                  data-field="f0"
                  maxlength="{{12}}"
                  bind:input="onInstValueInput"
                  placeholder="{{instanceFields[0].label}}"
                  input-align="right"
                  border="{{false}}"
                />
              </view>
              <view wx:if="{{instanceFields.length > 1}}" class="inst-amount-wrap">
                <van-field
                  value="{{inst.f1}}"
                  type="digit"
                  data-index="{{instIndex}}"
                  data-field="f1"
                  bind:input="onInstValueInput"
                  placeholder="{{instanceFields[1].label}}"
                  input-align="right"
                  border="{{false}}"
                />
              </view>
              <van-icon name="delete-o" class="inst-delete" bindtap="onInstDelete" data-index="{{instIndex}}" />
            </view>
          </view>
        </view>
      </view>

      <view class="instance-add-btn">
        <van-button type="primary" round block bindtap="onInstanceAdd">+ 添加</van-button>
      </view>
    </view>
  </van-popup>

</view>