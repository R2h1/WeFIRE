<view class="add-page">
  <view class="card">
    <text class="month-label">{{currentYear}}年{{currentMonth}}月</text>

    <!-- 资产 -->
    <view class="section-header">
      <text class="section-title"><text class="section-dot dot-assets"></text>资产</text>
      <van-button size="small" plain type="primary" bindtap="onAddItem" data-type="assets">+ 添加</van-button>
    </view>
    <view wx:for="{{assetEntries}}" wx:key="itemId" class="entry-row">
      <text class="entry-icon">{{item.icon}}</text>
      <text class="entry-name">{{item.name}}<text wx:if="{{item.label}}" class="entry-label"> · {{item.label}}</text></text>
      <input class="entry-amount" type="digit" placeholder="0" value="{{item.amount}}" data-itemid="{{item.itemId}}" bindinput="onAmountInput" />
      <van-icon name="cross" data-itemid="{{item.itemId}}" bindtap="onRemoveEntry" class="entry-del" />
    </view>
    <view wx:if="{{assetEntries.length === 0}}" class="empty-entries">
      <text>暂无资产分类，点击上方「+ 添加」开始设置</text>
    </view>

    <view class="section-divider"></view>

    <!-- 负债 -->
    <view class="section-header">
      <text class="section-title"><text class="section-dot dot-liabilities"></text>负债</text>
      <van-button size="small" plain type="primary" bindtap="onAddItem" data-type="liabilities">+ 添加</van-button>
    </view>
    <view wx:for="{{liabilityEntries}}" wx:key="itemId" class="entry-row">
      <text class="entry-icon">{{item.icon}}</text>
      <text class="entry-name">{{item.name}}<text wx:if="{{item.label}}" class="entry-label"> · {{item.label}}</text></text>
      <input class="entry-amount" type="digit" placeholder="0" value="{{item.amount}}" data-itemid="{{item.itemId}}" bindinput="onAmountInput" />
      <van-icon name="cross" data-itemid="{{item.itemId}}" bindtap="onRemoveEntry" class="entry-del" />
    </view>
    <view wx:if="{{liabilityEntries.length === 0}}" class="empty-entries">
      <text>暂无负债分类，点击上方「+ 添加」开始设置</text>
    </view>

    <!-- 预览 -->
    <view class="preview">
      <text class="preview-label">净资产</text>
      <text class="preview-amount">{{netWorthText}}</text>
    </view>

    <view class="btn-group-add">
      <van-button type="primary" round block bindtap="onSubmit">确认录入</van-button>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">历史记录</text>
    </view>
    <view wx:if="{{snapshots.length === 0}}" class="empty-entries">
      <text>暂无记录</text>
    </view>
    <view wx:else>
      <view class="history-entry" wx:for="{{snapshotsFormatted}}" wx:key="id">
        <text class="history-entry-label">{{item.label}}</text>
        <text class="history-entry-value">{{item.netWorthText}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 添加分类弹窗 -->
<van-popup show="{{showPicker}}" position="bottom" round bind:close="hidePicker">
  <view class="picker-content">
    <text class="picker-title">选择{{pickerType === 'assets' ? '资产' : '负债'}}分类</text>
    <scroll-view scroll-y class="picker-list">
      <view wx:for="{{availablePresets}}" wx:key="id" class="picker-item" data-preset="{{item.id}}" bindtap="onSelectPreset">
        <text class="picker-icon">{{item.icon}}</text>
        <text class="picker-name">{{item.name}}</text>
      </view>
      <view wx:if="{{availablePresets.length === 0}}" class="picker-empty">
        <text>已添加所有可用分类</text>
      </view>
    </scroll-view>
    <van-button block type="default" bindtap="hidePicker">取消</van-button>
  </view>
</van-popup>

<!-- 标签输入弹窗 -->
<van-popup show="{{showLabelInput}}" position="bottom" round bind:close="hideLabelInput">
  <view class="picker-content label-input-content">
    <text class="picker-title">设置账户标识（可选）</text>
    <text class="modal-label">为「{{selectedPresetName}}」设置一个名称</text>
    <van-field value="{{labelInput}}" placeholder="输入账户标识" bind:input="onLabelInput" border="{{false}}" />
    <view class="modal-btns">
      <van-button block type="default" bindtap="hideLabelInput">跳过</van-button>
      <van-button block type="primary" bindtap="onConfirmLabel">确定</van-button>
    </view>
  </view>
</van-popup>