/* ============================================
   Charts Page — 拟物态
   ============================================ */

.charts-page {
  background: #e6e0da;
  min-height: 100vh;
  padding: 8px 14px calc(52px + env(safe-area-inset-bottom));
}

/* ============================================
   Empty State
   ============================================ */

.charts-page .empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 20px;
}

.empty-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 48px 32px;
  text-align: center;
  box-shadow:
    6px 6px 14px var(--shadow-dark),
    -6px -6px 14px var(--shadow-light);
  width: 100%;
  max-width: 320px;
}

.empty-icon-bg {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  box-shadow:
    inset 3px 3px 8px var(--shadow-dark),
    inset -3px -3px 8px var(--shadow-light);
}

.empty-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin: 20px 0 8px;
}

.empty-subtitle {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  line-height: 1.5;
}

/* ============================================
   Content
   ============================================ */

.charts-content {
  padding-top: 4px;
}

.charts-page .card {
  margin: 0 0 10px;
  border-radius: var(--radius);
}

/* ============================================
   Chart Card
   ============================================ */

.chart-card {
  padding: 16px 16px 8px;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding: 0 4px;
}

.chart-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
}

.chart-date {
  font-size: 12px;
  color: var(--text-muted);
}

.chart-canvas {
  width: 100%;
  height: 200px;
}

/* ============================================
   Stats Row
   ============================================ */

.stats-row {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius);
  margin: 0 0 10px;
  padding: 20px 8px;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 11px;
  color: var(--text-muted);
  display: block;
  margin-bottom: 6px;
  letter-spacing: 0.5px;
}

.stat-value {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  display: block;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: #ebe5de;
  flex-shrink: 0;
}

/* ============================================
   Section Title
   ============================================ */

.section-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 14px;
}

/* ============================================
   Composition Card
   ============================================ */

.composition-card {
  padding: 20px;
}

.comp-row {
  display: flex;
  gap: 12px;
  margin-bottom: 2px;
}

.comp-item {
  flex: 1;
  text-align: center;
  padding: 10px 4px;
  background: #f2f2f7;
  border-radius: 8px;
}

.comp-label {
  font-size: 10px;
  color: var(--text-muted);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.comp-value {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.comp-liability {
  color: var(--danger);
}

.comp-divider {
  height: 0.5px;
  background: #ebe5de;
  margin: 16px 0;
}

/* ============================================
   Monthly Stats
   ============================================ */

.stats-card {
  padding: 20px;
}

.monthly-row {
  display: flex;
  align-items: center;
  padding: 10px 8px;
  border-radius: 8px;
}

.monthly-row + .monthly-row {
  border-top: 0.5px solid #ebe5de;
}

.monthly-month {
  font-size: 13px;
  color: var(--text-secondary);
  flex: 1;
  font-weight: 500;
}

.monthly-nw {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  margin-right: 12px;
}

.monthly-change {
  font-size: 14px;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  min-width: 80px;
  text-align: right;
}

.change-up {
  color: #4a9e6e;
}

.change-down {
  color: var(--danger);
}

/* ============================================
   History List
   ============================================ */

.history-card {
  padding: 20px;
}

.history-row {
  padding: 12px 8px;
  border-radius: 8px;
}

.history-row + .history-row {
  border-top: 0.5px solid #ebe5de;
}

.history-month {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  display: block;
  margin-bottom: 6px;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 3px 0;
}

.history-label {
  font-size: 12px;
  color: var(--text-muted);
}

.history-value {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}
