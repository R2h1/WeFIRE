<view class="settings-page">
  <view class="card">
    <text class="label">目标金额</text>
    <input class="input-field" type="digit" placeholder="输入你的 FIRE 目标金额" value="{{targetAmount}}" bindinput="onTargetInput" />
    <view style="height:20px"></view>
    <text class="label">预计退休年份</text>
    <input class="input-field" type="digit" placeholder="输入预计退休的年份" value="{{retirementYear}}" bindinput="onYearInput" />
  </view>

  <view class="btn-group">
    <button class="btn-primary" bindtap="onSave">保存设置</button>
  </view>

  <view class="section-divider"></view>

  <view class="card backup-section">
    <text class="section-title">数据备份与恢复</text>
    <view class="btn-row">
      <button class="btn-secondary" bindtap="onExport">导出备份</button>
      <button class="btn-secondary" bindtap="onImport">导入恢复</button>
    </view>
  </view>
</view>