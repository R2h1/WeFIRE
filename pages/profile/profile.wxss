/* ============================================
   我的 — 拟物态暖橙风格
   ============================================ */

.history-page {
  --card-bg: #FBF9F7;
  --shadow-dark: #D6CFC7;
  --shadow-light: #FFFFFF;
  --text: #2D2A26;
  --text-secondary: #8B827A;
  --accent: #EA580C;
  --accent-soft: #FFF5F0;
  --danger: #C06C5C;
  --radius: 14px;

  background: #E6E0DA;
  min-height: 100vh;
  padding: 0 14px 32px;
}

/* ===== 卡片通用拟物态 ===== */
.history-page .card {
  background: var(--card-bg);
  border-radius: var(--radius);
  margin: 10px 0;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
}

/* ===== 头像卡片 ===== */
.profile-card {
  display: flex;
  align-items: center;
  padding: 18px 20px;
  margin-top: 16px;
}

.profile-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 14px;
}

.avatar-text {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 17px;
  font-weight: 700;
  color: var(--text);
  display: block;
}

.profile-desc {
  font-size: 12px;
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

/* ===== FIRE 目标卡片 ===== */
.settings-card {
  padding: 20px;
}

.settings-card-hover {
  box-shadow:
    inset 3px 3px 8px rgba(0, 0, 0, 0.05),
    inset -3px -3px 8px rgba(255, 255, 255, 0.7);
  background: #F8F5F2;
}

.settings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.settings-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.settings-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--accent-soft);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
}

.settings-chevron {
  font-size: 22px;
  color: #BFB5AA;
  line-height: 1;
}

.settings-body {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 14px 16px;
  background: #f2f2f7;
  border-radius: 10px;
}

.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.settings-row-label {
  font-size: 13px;
  color: var(--text-secondary);
}

.settings-row-value {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}

.settings-empty {
  padding: 16px;
  text-align: center;
  background: #f2f2f7;
  border-radius: 10px;
  color: #BFB5AA;
  font-size: 14px;
}

/* ===== 菜单项 ===== */
.history-page van-cell-group {
  display: block;
  margin: 10px 0;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
}

.history-page van-cell-group van-cell {
  background: var(--card-bg);
}

.van-cell-icon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  margin-right: 12px;
  flex-shrink: 0;
}

.icon-bell {
  background: #FFF5F0;
  color: var(--accent);
}

.icon-export {
  background: #EDE8E3;
  color: var(--text-secondary);
}

.icon-import {
  background: var(--accent-soft);
  color: var(--accent);
}

.icon-danger {
  background: #FFEBEE;
  color: var(--danger);
}

/* 危险操作区 */
.danger-section {
  margin: 10px 0;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
}

.danger-section van-cell {
  background: var(--card-bg);
}

.danger-text {
  color: var(--danger);
}

/* ===== Dialog 弹窗 ===== */
.van-dialog-content {
  padding: 20px 20px 0;
}

.van-dialog-title {
  display: block;
  font-size: 17px;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  margin-bottom: 12px;
}

.van-dialog-content van-cell-group {
  margin: 0;
  box-shadow: none;
}

.van-dialog {
  --van-dialog-border-radius: 16px;
}

.van-dialog__footer .van-dialog__confirm {
  flex: 1;
  width: 100%;
  border-radius: 0 !important;
}

.van-dialog__footer .van-button:first-child {
  border-bottom-left-radius: 16px !important;
}

.van-dialog__footer .van-button:last-child {
  border-bottom-right-radius: 16px !important;
}

.van-dialog-content van-field {
  --van-field-background: #f2f2f7;
  padding: 2px 0;
}

.import-textarea {
  --van-field-background: #f2f2f7;
  border-radius: 8px;
}

.import-tip {
  font-size: 13px;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 12px;
}

/* ===== Picker ===== */
.picker-value {
  width: 100%;
  text-align: right;
  color: var(--text);
}

.picker-placeholder {
  width: 100%;
  text-align: right;
  color: #BFB5AA;
}

van-popup .van-picker {
  --van-picker-option-font-size: 18px;
  --van-picker-title-font-size: 16px;
  --van-picker-title-color: var(--text);
  --van-picker-cancel-action-color: var(--text-secondary);
  --van-picker-confirm-action-color: var(--accent);
}

van-popup .van-picker__toolbar {
  border-bottom: 1px solid #EBE5DE;
}
