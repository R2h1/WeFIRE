.trend-page {
  padding-bottom: 30px;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
  padding: 12px 8px;
}

.stat-item {
  flex: 1;
  padding: 0 4px;
}

.stat-label {
  font-size: 11px;
  color: #C7C7CC;
  display: block;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.stat-value {
  font-size: 18px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}