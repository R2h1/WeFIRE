/* ============================================
   Home Page Styles
   ============================================ */

.home-page {
  padding-bottom: 8px;
}

.home-content {
  padding-top: 12px;
}

/* ============================================
   Progress Card
   ============================================ */

.progress-card {
  text-align: center;
  padding: 32px 24px 28px;
  position: relative;
  overflow: hidden;
}

.pct-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12px;
  margin-bottom: 4px;
}

.pct-value {
  font-size: 72px;
  font-weight: 700;
  color: #1C1C1E;
  letter-spacing: -3px;
  line-height: 1;
}

.pct-unit {
  font-size: 22px;
  color: #8E8E93;
  font-weight: 400;
  letter-spacing: 0;
}

.achieved-chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 16px;
  background: #E8F5E9;
  color: #2E7D32;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
}

.bar-track {
  width: 100%;
  height: 6px;
  background: #F2F2F7;
  border-radius: 3px;
  overflow: hidden;
  margin: 24px 0 16px;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7D32, #4CAF50);
  border-radius: 3px;
  transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

.progress-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.meta-label {
  font-size: 13px;
  color: #8E8E93;
}

.meta-sep {
  margin: 0 2px;
}

.meta-value {
  font-size: 14px;
  font-weight: 600;
  color: #1C1C1E;
  margin-right: 4px;
}

/* ============================================
   Summary Card
   ============================================ */

.summary-card {
  text-align: center;
  padding: 24px 20px;
}

.summary-card .summary-label {
  font-size: 13px;
  font-weight: 500;
  color: #8E8E93;
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.summary-amount {
  font-size: 48px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  letter-spacing: -2px;
  line-height: 1.1;
  margin-bottom: 24px;
}

.summary-detail {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20px;
  border-top: 1px solid #F2F2F7;
  gap: 0;
}

.summary-detail-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.detail-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-green {
  background: #2E7D32;
}

.dot-amber {
  background: #D32F2F;
}

.detail-label {
  font-size: 13px;
  color: #8E8E93;
}

.detail-value {
  font-size: 15px;
  font-weight: 600;
  color: #1C1C1E;
}

.summary-divider {
  width: 1px;
  height: 24px;
  background: #F2F2F7;
  margin: 0 8px;
}

/* ============================================
   Info Card
   ============================================ */

.info-card {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 20px;
}

.info-icon {
  font-size: 18px;
  color: #2E7D32;
  flex-shrink: 0;
  margin-top: 2px;
}

.info-body {
  flex: 1;
}

.info-text {
  font-size: 15px;
  color: #636366;
  line-height: 1.5;
  display: block;
}

.info-highlight {
  font-weight: 700;
  color: #2E7D32;
}

.info-sub {
  font-size: 12px;
  color: #C7C7CC;
  display: block;
  margin-top: 4px;
}

/* ============================================
   Chart Card
   ============================================ */

.chart-card {
  padding: 16px 16px 8px;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding: 0 4px;
}

.chart-title {
  font-size: 13px;
  font-weight: 600;
  color: #8E8E93;
  letter-spacing: 0.3px;
}

.chart-date {
  font-size: 12px;
  color: #C7C7CC;
}

.chart-canvas {
  width: 100%;
  height: 200px;
}

/* ============================================
   Stats Row
   ============================================ */

.stats-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16px;
  margin: 0 16px;
  padding: 20px 8px;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 11px;
  color: #C7C7CC;
  display: block;
  margin-bottom: 6px;
  letter-spacing: 0.5px;
}

.stat-value {
  font-size: 20px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: #F2F2F7;
  flex-shrink: 0;
}
