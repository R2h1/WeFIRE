.home-page {
  padding: 0 0 30px;
}

/* Empty state */
.empty-state {
  padding: 140px 40px 60px;
  text-align: center;
}

.empty-icon {
  font-size: 64px;
  display: block;
  margin-bottom: 20px;
}

.empty-text {
  font-size: 18px;
  font-weight: 600;
  color: #1c1c1e;
  display: block;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 15px;
  color: #8e8e93;
  line-height: 1.6;
  display: block;
}

/* Progress card */
.progress-card {
  text-align: center;
  padding: 36px 24px 28px;
  margin-top: 16px;
  position: relative;
  overflow: hidden;
}

.progress-icon {
  font-size: 28px;
  display: block;
  margin-bottom: 8px;
}

.progress-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 4px;
  background: #2e7d32;
  border-radius: 0 0 4px 4px;
}

.progress-pct {
  font-size: 64px;
  font-weight: 700;
  color: #1c1c1e;
  letter-spacing: -3px;
  line-height: 1;
  display: block;
}

.progress-pct-unit {
  font-size: 24px;
  color: #8e8e93;
  font-weight: 400;
}

.bar-bg {
  width: 100%;
  height: 4px;
  background: #e5e5ea;
  border-radius: 2px;
  overflow: hidden;
  margin: 20px 0 16px;
}

.bar-fill {
  height: 100%;
  background: #2e7d32;
  border-radius: 2px;
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

.progress-target {
  font-size: 15px;
  color: #8e8e93;
  display: block;
}

.progress-target-amount {
  font-weight: 600;
  color: #1c1c1e;
}

.achieved-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
  padding: 8px 20px;
  background: #e8f5e9;
  color: #2e7d32;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
}

/* Summary card */
.summary-card {
  text-align: center;
  padding: 24px;
}

.summary-label {
  font-size: 13px;
  color: #8e8e93;
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.summary-amount {
  font-size: 44px;
  font-weight: 700;
  color: #1c1c1e;
  display: block;
  letter-spacing: -2px;
  line-height: 1.1;
}

.summary-detail {
  display: flex;
  justify-content: center;
  gap: 32px;
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid #f2f2f7;
}

.detail-item {
  font-size: 14px;
  color: #8e8e93;
  display: flex;
  align-items: center;
  gap: 4px;
}

.detail-item-value {
  font-weight: 600;
  color: #1c1c1e;
}

.dot-green,
.dot-amber {
  font-size: 8px;
  line-height: 1;
}

.target-dot {
  font-size: 10px;
  color: #2e7d32;
}

/* Info card */
.info-card {
  text-align: center;
  padding: 22px 24px;
}

.info-text {
  font-size: 15px;
  color: #636366;
  line-height: 1.6;
}

.info-highlight {
  font-weight: 700;
  color: #2e7d32;
  font-size: 18px;
}

/* Recent section */
.recent-section {
  margin: 20px 16px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8px;
}

.recent-section text {
  font-size: 12px;
  color: #c7c7cc;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}
