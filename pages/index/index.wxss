/* ============================================
   Home Page — 拟物态卡片
   ============================================ */

.home-page {
  background: #e6e0da;
  min-height: 100vh;
  padding: 8px 14px calc(52px + env(safe-area-inset-bottom));
}

.home-content {
  padding-top: 4px;
}

/* ============================================
   Hero Card
   ============================================ */

.hero-card {
  text-align: center;
  padding: 28px 24px 24px;
  border-radius: var(--radius-lg);
  margin: 0;
}

.hero-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 2px;
}

.hero-pct-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0;
  margin-bottom: 8px;
}

.hero-pct-value {
  font-size: 56px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -2px;
  line-height: 1;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.hero-pct-unit {
  font-size: 24px;
  color: var(--text-secondary);
  font-weight: 400;
  letter-spacing: 0;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
}

.hero-achieved-chip {
  display: inline-flex;
  align-items: center;
  padding: 4px 14px;
  background: var(--accent-soft);
  color: var(--accent);
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  margin-left: 10px;
}

.hero-bar-track {
  width: 100%;
  height: 10px;
  background: var(--progress-bg);
  border-radius: 5px;
  box-shadow:
    inset 2px 2px 4px var(--shadow-dark),
    inset -1px -1px 3px var(--shadow-light);
  overflow: hidden;
  margin: 20px 0;
}

.hero-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #f97316, #ea580c);
  border-radius: 5px;
  box-shadow: 0 0 10px var(--accent-glow);
  transition: width 0.6s cubic-bezier(0.25, 0.8, 0.25, 1.2);
}

.hero-separator {
  height: 0.5px;
  background: #ebe5de;
  margin: 20px 0 16px;
}

.hero-meta-row {
  display: flex;
  justify-content: space-around;
}

.hero-meta-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.hero-meta-label {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.hero-meta-value-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.hero-meta-value {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  letter-spacing: -0.5px;
}

.hero-meta-sub {
  font-size: 11px;
  color: var(--text-muted);
}

.hero-change-chip {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 20px;
}

.change-up {
  background: rgba(76, 175, 80, 0.12);
  color: #4CAF50;
}

.change-down {
  background: rgba(192, 108, 92, 0.12);
  color: var(--danger);
}

/* ============================================
   Summary Strips
   ============================================ */

.summary-strips {
  display: flex;
  gap: 10px;
  margin: 10px 0;
}

.strip-card {
  flex: 1;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 18px 14px;
  text-align: center;
  box-shadow:
    3px 3px 8px var(--shadow-dark),
    -3px -3px 8px var(--shadow-light);
}

.strip-label {
  font-size: 10px;
  color: var(--text-secondary);
  letter-spacing: 1px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 6px;
}

.strip-value {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  display: block;
  font-family: 'SF Mono', 'Menlo', 'Consolas', 'PingFang SC', monospace;
  letter-spacing: -0.5px;
}

.strip-breakdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3px;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 0.5px solid #ebe5de;
  font-size: 11px;
}

.strip-sub-label {
  color: var(--text-muted);
}

.strip-sub-value {
  color: var(--text-secondary);
  font-weight: 600;
}

.strip-sub-sep {
  color: #e0d9d1;
  margin: 0 2px;
}

/* ============================================
   Entry Button
   ============================================ */

.entry-btn {
  display: block;
  width: 100%;
  background: var(--accent);
  color: #fff;
  border-radius: 25px;
  padding: 16px 0;
  text-align: center;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.3px;
  box-shadow: 0 4px 14px var(--accent-glow);
  margin: 10px 0 16px;
}

.entry-btn-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ============================================
   Empty State
   ============================================ */

.home-page .empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 20px;
}

.empty-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 48px 32px;
  text-align: center;
  box-shadow:
    6px 6px 14px var(--shadow-dark),
    -6px -6px 14px var(--shadow-light);
  width: 100%;
  max-width: 320px;
}

.empty-icon-bg {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  box-shadow:
    inset 3px 3px 8px var(--shadow-dark),
    inset -3px -3px 8px var(--shadow-light);
}

.empty-icon-text {
  font-size: 28px;
}

.empty-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin: 20px 0 8px;
}

.empty-subtitle {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24px;
  line-height: 1.5;
}

.empty-btn {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  padding: 14px 36px;
  border-radius: 25px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.3px;
  box-shadow: 0 4px 14px var(--accent-glow);
}

.empty-btn-hover {
  transform: scale(0.95);
  opacity: 0.85;
}
