<view class="home-page">
  <!-- Empty State -->
  <view wx:if="{{!hasSettings}}" class="empty-state">
    <view class="empty-card">
      <view class="empty-icon-bg">
        <text class="empty-icon-text">🎯</text>
      </view>
      <text class="empty-title">还未设定 FIRE 目标</text>
      <text class="empty-subtitle">设定目标后即可查看进度与资产趋势</text>
      <view class="empty-btn" hover-class="empty-btn-hover" bindtap="onTapEmptyState">开始规划</view>
    </view>
  </view>

  <!-- Main Content -->
  <view wx:else class="home-content">
    <!-- Hero Card -->
    <view class="card hero-card">
      <text class="hero-label">距 FIRE 还有</text>
      <view class="hero-pct-row">
        <text class="hero-pct-value">{{progressPercent}}</text>
        <text class="hero-pct-unit">%</text>
        <view wx:if="{{isAchieved}}" class="hero-achieved-chip">已达成</view>
      </view>
      <view class="hero-bar-track">
        <view class="hero-bar-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <view class="hero-separator"></view>
      <view class="hero-meta-row">
        <view class="hero-meta-item" bindtap="onTapNetWorth">
          <text class="hero-meta-label">净资产</text>
          <view class="hero-meta-value-row">
            <text class="hero-meta-value">{{netWorthText}}</text>
            <view wx:if="{{netWorthChangePct}}" class="hero-change-chip {{netWorthChangePos ? 'change-up' : 'change-down'}}">
              <text>{{netWorthChangePos ? '↑' : '↓'}}{{netWorthChangePct}}%</text>
            </view>
          </view>
        </view>
        <view class="hero-meta-item">
          <text class="hero-meta-label">FIRE 目标</text>
          <text class="hero-meta-value">{{formatTarget}}</text>
          <text class="hero-meta-sub">{{retirementYearText}}</text>
        </view>
      </view>
    </view>

    <!-- Summary Strips -->
    <view class="summary-strips">
      <view class="strip-card">
        <text class="strip-label">总资产</text>
        <text class="strip-value">{{assetsText}}</text>
        <view class="strip-breakdown">
          <text class="strip-sub-label">流动</text>
          <text class="strip-sub-value">{{liquidAssetsText}}</text>
          <text class="strip-sub-sep">/</text>
          <text class="strip-sub-label">固定</text>
          <text class="strip-sub-value">{{fixedAssetsText}}</text>
        </view>
      </view>
      <view class="strip-card">
        <text class="strip-label">总负债</text>
        <text class="strip-value">{{liabilitiesText}}</text>
        <view class="strip-breakdown">
          <text class="strip-sub-label">短期</text>
          <text class="strip-sub-value">{{shortLiabilitiesText}}</text>
          <text class="strip-sub-sep">/</text>
          <text class="strip-sub-label">长期</text>
          <text class="strip-sub-value">{{longLiabilitiesText}}</text>
        </view>
      </view>
    </view>

    <!-- Entry Button -->
    <view class="entry-btn" hover-class="entry-btn-hover" bindtap="onTapEntry">
      <text>录入本月数据</text>
    </view>
  </view>
</view>
