page {
  background-color: #F2F2F5;
  color: #1C1C1E;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
  font-size: 15px;
  line-height: 1.6;
}

view, scroll-view, swiper {
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 28px 24px;
  margin: 6px 16px;
}

.btn-primary {
  background-color: #2E7D32;
  color: #FFFFFF;
  border-radius: 12px;
  padding: 18px 24px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  border: none;
  width: 100%;
  letter-spacing: 0.3px;
}

.btn-primary:active {
  background-color: #25682A;
}

.btn-secondary {
  background-color: #F2F2F7;
  color: #1C1C1E;
  border-radius: 12px;
  padding: 18px 24px;
  font-size: 15px;
  font-weight: 500;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-secondary:active {
  background-color: #E5E5EA;
}

.ipt-wrapper {
  background: #F2F2F7;
  border-radius: 12px;
  padding: 18px 16px;
}

.input-field {
  width: 100%;
  background: transparent;
  border: none;
  font-size: 17px;
  color: #1C1C1E;
  caret-color: #2E7D32;
}

.input-field::placeholder {
  color: #C7C7CC;
}

.input-field:focus {
  background: #E8F5E9;
}

.label {
  font-size: 13px;
  color: #8E8E93;
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120px;
  padding-left: 40px;
  padding-right: 40px;
  color: #8E8E93;
}

.empty-state text {
  font-size: 16px;
  margin-top: 12px;
  line-height: 1.6;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 340px;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 28px 24px 20px;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 24px;
  text-align: center;
}

.modal-field {
  margin-bottom: 16px;
}

.modal-label {
  font-size: 13px;
  color: #8E8E93;
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.input-wrapper {
  background: #F2F2F7;
  border-radius: 12px;
  padding: 14px 16px;
}

.modal-input {
  width: 100%;
  background: transparent;
  border: none;
  font-size: 17px;
  color: #1C1C1E;
  caret-color: #2E7D32;
}

.modal-input::placeholder {
  color: #C7C7CC;
}

.modal-btns {
  display: flex;
  gap: 10px;
  margin-top: 28px;
}

.modal-btn {
  flex: 1;
  border-radius: 12px;
  padding: 16px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  border: none;
}

.modal-btn.cancel {
  background: #F2F2F7;
  color: #1C1C1E;
}

.modal-btn.cancel:active {
  background: #E5E5EA;
}

.modal-btn.confirm {
  background: #2E7D32;
  color: #FFFFFF;
}

.modal-btn.confirm:active {
  background: #25682A;
}