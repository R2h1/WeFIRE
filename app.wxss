/* ============================================
   WeFIRE Design System — Global Styles
   ============================================
   Color tokens:
     --green-primary: #2E7D32 (primary brand)
     --green-dark:    #25682A (pressed)
     --green-bg:      #E8F5E9 (badge/background)
     --red-danger:    #FF3B30
     --red-dark:      #1A1A1A
     --gray-900:      #1C1C1E (primary text)
     --gray-600:      #8E8E93 (secondary text)
     --gray-400:      #C7C7CC (placeholder/disabled)
     --gray-200:      #E5E5EA (dividers)
     --gray-100:      #F2F2F7 (surface bg)
     --gray-50:       #F2F2F5 (page bg)
     --white:         #FFFFFF
   Spacing: 4/8/12/16/20/24/28/32
   Border-radius: 8/12/16/20
   Typography: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif
*/

page {
  background-color: #f2f2f5;
  color: #1c1c1e;
  font-family:
    -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue',
    sans-serif;
  font-size: 15px;
  line-height: 1.6;

  /* Vant Weapp theme */
  --van-primary-color: #ea580c;
  --van-button-primary-background: #ea580c;
  --van-button-primary-border-color: #ea580c;
  --van-button-radius: 12px;
  --van-cell-vertical-padding: 16px;
  --van-cell-horizontal-padding: 20px;
  --van-cell-font-size: 15px;
  --van-cell-group-background: transparent;
  --van-cell-background: #ffffff;
  --van-cell-border-color: #f2f2f7;
  --van-field-label-width: 4.5em;
  --van-dialog-border-radius: 20px;
  --van-popup-border-radius: 20px;
  --van-toast-border-radius: 12px;
  --van-button-default-height: 52px;
  --van-cell-icon-size: 20px;
}

view,
scroll-view,
swiper {
  box-sizing: border-box;
}

/* ============================================
   Layout Utilities
   ============================================ */

.page {
  padding-bottom: 32px;
}

.page-section {
  margin-top: 16px;
}

.page-section:first-child {
  margin-top: 0;
}

/* ============================================
   Card
   ============================================ */

.card {
  background: #ffffff;
  border-radius: 16px;
  padding: 24px 20px;
  margin: 8px 16px;
}

.card + .card {
  margin-top: 8px;
}

/* ============================================
   Buttons
   ============================================ */

.btn-primary {
  background-color: #ea580c;
  color: #ffffff;
  border-radius: 12px;
  padding: 18px 24px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  border: none;
  width: 100%;
  letter-spacing: 0.3px;
  position: relative;
  overflow: hidden;
}

.btn-primary:active {
  opacity: 0.95;
}

.btn-secondary {
  background-color: #f2f2f7;
  color: #1c1c1e;
  border-radius: 12px;
  padding: 18px 24px;
  font-size: 15px;
  font-weight: 500;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-secondary:active {
  background-color: #e5e5ea;
}

/* ============================================
   Input Fields
   ============================================ */

.ipt-wrapper {
  background: #f2f2f7;
  border-radius: 12px;
  padding: 16px 18px;
}

.ipt-wrapper:focus-within {
  background: #e8f5e9;
  outline: 2px solid rgba(46, 125, 50, 0.2);
  outline-offset: -2px;
}

.input-field {
  width: 100%;
  background: transparent;
  border: none;
  font-size: 17px;
  color: #1c1c1e;
  caret-color: #2e7d32;
}

.input-field::placeholder {
  color: #c7c7cc;
}

/* ============================================
   Labels
   ============================================ */

.label {
  font-size: 13px;
  color: #8e8e93;
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

/* ============================================
   Empty State
   ============================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 40px;
  color: #8e8e93;
  text-align: center;
}

.empty-state .empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.6;
}

.empty-state .empty-title {
  font-size: 18px;
  font-weight: 600;
  color: #1c1c1e;
  margin-bottom: 8px;
}

.empty-state .empty-desc {
  font-size: 15px;
  color: #8e8e93;
  line-height: 1.6;
}

/* ============================================
   Section Header
   ============================================ */

.section-header-inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 12px;
  margin-top: 8px;
}

.section-header-inline .section-title-small {
  font-size: 13px;
  font-weight: 600;
  color: #8e8e93;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

/* ============================================
   Modal / Dialog Shared Styles
   ============================================ */

.modal-label {
  font-size: 13px;
  color: #8e8e93;
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}
