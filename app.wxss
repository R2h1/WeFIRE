/* ============================================
   WeFIRE Design System — Global Styles (Neumorphic)
   ============================================
   Color tokens:
     --accent:        #ea580c (efficiency orange)
     --accent-soft:   #fff5f0
     --accent-glow:   rgba(234, 88, 12, 0.25)
     --danger:        #c06c5c
     --card-bg:       #fbf9f7
     --shadow-dark:   #d6cfc7
     --shadow-light:  #ffffff
     --text:          #2d2a26
     --text-secondary:#8b827a
     --text-muted:    #bfb5aa
     --progress-bg:   #e8e2db
     --radius-sm:     10px
     --radius:        14px
     --radius-lg:     18px
     --radius-xl:     22px
   Spacing: 4/8/12/16/20/24/28/32
   Typography: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif
*/

page {
  background-color: #e6e0da;
  color: #2d2a26;
  font-family:
    -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue',
    sans-serif;
  font-size: 15px;
  line-height: 1.6;

  /* Global neumorphic tokens */
  --card-bg: #fbf9f7;
  --shadow-dark: #d6cfc7;
  --shadow-light: #ffffff;
  --text: #2d2a26;
  --text-secondary: #8b827a;
  --text-muted: #bfb5aa;
  --accent: #ea580c;
  --accent-soft: #fff5f0;
  --accent-glow: rgba(234, 88, 12, 0.25);
  --danger: #c06c5c;
  --progress-bg: #e8e2db;
  --radius-sm: 10px;
  --radius: 14px;
  --radius-lg: 18px;
  --radius-xl: 22px;

  /* Vant Weapp theme */
  --van-primary-color: #ea580c;
  --van-button-primary-background: #ea580c;
  --van-button-primary-border-color: #ea580c;
  --van-button-radius: 12px;
  --van-cell-vertical-padding: 16px;
  --van-cell-horizontal-padding: 20px;
  --van-cell-font-size: 15px;
  --van-cell-group-background: transparent;
  --van-cell-background: #fbf9f7;
  --van-cell-border-color: #ebe5de;
  --van-field-label-width: 4.5em;
  --van-dialog-border-radius: 20px;
  --van-popup-border-radius: 20px;
  --van-toast-border-radius: 12px;
  --van-button-default-height: 52px;
  --van-cell-icon-size: 20px;
}

view,
scroll-view,
swiper {
  box-sizing: border-box;
}

/* ============================================
   Layout Utilities
   ============================================ */

.page {
  padding-bottom: 32px;
}

.page-section {
  margin-top: 16px;
}

.page-section:first-child {
  margin-top: 0;
}

/* ============================================
   Card — Neumorphic
   ============================================ */

.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24px 20px;
  margin: 8px 16px;
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -4px -4px 10px var(--shadow-light);
}

.card + .card {
  margin-top: 10px;
}

/* ============================================
   Buttons
   ============================================ */

.btn-primary {
  background-color: var(--accent);
  color: #ffffff;
  border-radius: 25px;
  padding: 16px 24px;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  border: none;
  width: 100%;
  letter-spacing: 0.3px;
  box-shadow: 0 4px 14px var(--accent-glow);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.97);
}

.btn-secondary {
  background-color: #ede8e3;
  color: var(--text);
  border-radius: 25px;
  padding: 16px 24px;
  font-size: 15px;
  font-weight: 500;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-secondary:active {
  background-color: #e0d9d1;
}

/* ============================================
   Input Fields
   ============================================ */

.ipt-wrapper {
  background: #f2f2f7;
  border-radius: var(--radius-sm);
  padding: 16px 18px;
}

.ipt-wrapper:focus-within {
  background: var(--accent-soft);
  outline: 2px solid rgba(234, 88, 12, 0.2);
  outline-offset: -2px;
}

.input-field {
  width: 100%;
  background: transparent;
  border: none;
  font-size: 17px;
  color: var(--text);
  caret-color: var(--accent);
}

.input-field::placeholder {
  color: var(--text-muted);
}

/* ============================================
   Labels
   ============================================ */

.label {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

/* ============================================
   Empty State
   ============================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 40px;
  color: var(--text-secondary);
  text-align: center;
}

.empty-state .empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.8;
}

.empty-state .empty-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
}

.empty-state .empty-desc {
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ============================================
   Section Header
   ============================================ */

.section-header-inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 12px;
  margin-top: 8px;
}

.section-header-inline .section-title-small {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

/* ============================================
   Modal / Dialog Shared Styles
   ============================================ */

.modal-label {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}
